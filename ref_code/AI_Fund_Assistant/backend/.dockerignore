# ============================================================================
# 基金量化交易系统 — 后端 Docker 忽略文件
# 减少构建上下文大小，排除不需要的文件
# ============================================================================

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# 虚拟环境
venv/
.venv/
env/

# 环境变量文件（通过 env_file 或 -e 传入）
.env
.env.local
.env.*.local

# 测试相关
tests/
.pytest_cache/
.coverage
htmlcov/
.tox/

# IDE 配置
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db

# 数据库文件（通过 volume 挂载）
data/

# 日志
*.log

# 文档
*.md
docs/
