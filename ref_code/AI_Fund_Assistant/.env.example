# ============================================================================
# 基金量化交易系统 — 环境变量配置示例
# 复制此文件为 .env 并填写实际值: cp .env.example .env
# ============================================================================

# ── 数据库配置 ──────────────────────────────────────────────────────────
# 数据库目录（Docker 中默认 /app/data，本地开发默认 data/）
FUND_QUANT_DATABASE_DIR=data/

# 数据库文件名
FUND_QUANT_DATABASE_NAME=fund_quant.db

# ── 服务配置 ──────────────────────────────────────────────────────────
# 监听地址（Docker 中必须为 0.0.0.0）
FUND_QUANT_HOST=0.0.0.0

# 监听端口
FUND_QUANT_PORT=8000

# 调试模式（生产环境设为 false）
FUND_QUANT_DEBUG=false

# ── CORS 配置 ────────────────────────────────────────────────────────
# 允许的跨域来源，多个用逗号分隔
# Docker 部署时需包含 nginx 所在域
FUND_QUANT_CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173,http://localhost:3000

# ── AI 模型配置 ──────────────────────────────────────────────────────
# 默认 AI 模型名称
DEFAULT_AI_MODEL=deepseek

# AI API Key（必填，否则 AI 功能不可用）
DEFAULT_AI_API_KEY=your-api-key-here

# AI API 基础 URL
DEFAULT_AI_BASE_URL=https://api.deepseek.com/v1

# ── 飞书推送配置（旧版兼容，后端也使用这些变量）──────────────────────────
# 飞书机器人Webhook URL
FEISHU_WEBHOOK_URL=

# 飞书签名密钥（可选）
FEISHU_WEBHOOK_SECRET=

# ── 数据源配置 ──────────────────────────────────────────────────────────
# TuShare Pro Token（用于次级数据源，https://tushare.pro 注册获取）
# 留空则跳过此数据源，仅使用 AKShare + BaoStock 等免费数据源
TUSHARE_TOKEN=

# ── 时区 ──────────────────────────────────────────────────────────────
TZ=Asia/Shanghai
